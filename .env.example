# Copy this file to .env and fill in real values. Never commit the real .env.

# --- App ---
ENVIRONMENT=local
API_BASE_URL=http://localhost:8000
# Shared demo login password (NOT secure -- fine for a capstone demo only).
DEMO_SHARED_PASSWORD=password1

# --- Database ---
# Local quick-iteration fallback (no docker needed):
# DATABASE_URL=sqlite:///./local.db
# Docker Compose Postgres (see docker-compose.yml, added in a later step):
DATABASE_URL=postgresql+psycopg2://agent:localdev@localhost:5432/insurance_support

# --- OpenAI (IITM-provided key + custom base url) ---
OPENAI_API_KEY=your-iitm-provided-key
OPENAI_BASE_URL=https://your-iitm-provided-base-url/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
# Model names are case-sensitive and provider-specific -- check your IITM/
# Vocareum guide for the exact supported model list before assuming a name.
CHAT_MODEL=gpt-4o-mini

# --- Pinecone (two separate indexes, both 1536-dim to match the embedding model) ---
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_POLICIES_INDEX=policies
PINECONE_CUSTOMER_MEMORY_INDEX=customer-memory

# --- Observability (optional) ---
# Set LANGSMITH_TRACING=true and provide your key to see every LLM call,
# tool call, and graph node in the LangSmith UI. Leave TRACING=false (or
# key blank) to run with tracing off -- LangChain silently no-ops in that case.
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=motor-insurance-support-agent
LANGSMITH_TRACING=true

# --- Escalation business rules ---
# Tune these without touching code. See graph/nodes.py _evaluate_escalation
# for exactly how each is used.
HIGH_VALUE_CLAIM_THRESHOLD=100000
MAX_TICKETS_PER_30_DAYS=2
REPEAT_TICKET_WINDOW_DAYS=30
SUPERVISOR_AGENT_NAME=Arjun Mehta
